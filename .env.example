# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coe_nexus?schema=public"

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-minimum-32-chars"
JWT_EXPIRES_IN="7d"

# ── API server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ── Storage (S3-compatible) ──────────────────────────────────────────────────
S3_BUCKET="coe-nexus-documents"
S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ── Web app (prefix with NEXT_PUBLIC_ to expose to browser) ─────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/v1"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
